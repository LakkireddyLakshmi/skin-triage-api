# Copy this file to ".env" and fill in real values for local development.
ENVIRONMENT=development

# Step 3+ : database connection. Leave as-is to use a local SQLite file.
DATABASE_URL=sqlite+aiosqlite:///./skin_triage.db

# Step 2+ : used to sign login tokens. Use a long random string in production.
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Step 4 : the deployed model that performs the prediction.
HF_SPACE_URL=https://huggingface.co/spaces/sweety783/skin-disease-classifier
